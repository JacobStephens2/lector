# Copy to a root-owned file outside the web root (e.g. /etc/lector/lector.env)
# and load it via the systemd unit's EnvironmentFile=. Never commit the real values.

# Required: OpenAI key used only for the text-to-speech call.
OPENAI_API_KEY=sk-...

# Public base URL, used in emailed links.
LECTOR_BASE_URL=https://lector.example.com

# Optional SMTP for account/verification email (defaults shown are for Resend).
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_FROM=you@example.com

# Set to 1 only behind a server that supports X-Sendfile (e.g. Apache mod_xsendfile).
LECTOR_XSENDFILE=
